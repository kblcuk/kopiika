{
	"name": "kopiika",
	"main": "expo-router/entry",
	"version": "0.0.16",
	"scripts": {
		"start": "expo start",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"ios:setup": "fnox exec -- bundle exec fastlane setup_signing",
		"ios:build": "fnox exec -- bundle exec fastlane build",
		"ios:upload": "fnox exec -- bundle exec fastlane upload",
		"ios:beta": "fnox exec -- bundle exec fastlane beta",
		"web": "expo start --web",
		"test": "bun run test:unit && bun run test:component",
		"test:unit": "bun test src/db src/store src/utils",
		"test:component": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "bun test --coverage && jest --coverage",
		"lint": "expo lint",
		"format": "prettier --write .",
		"generate:splash": "bun run scripts/generate-splash.ts",
		"format:check": "prettier --check .",
		"types": "tsc --noEmit",
		"release": "commit-and-tag-version",
		"release:minor": "commit-and-tag-version --release-as minor",
		"release:major": "commit-and-tag-version --release-as major"
	},
	"commit-and-tag-version": {
		"bumpFiles": [
			{
				"filename": "package.json",
				"type": "json"
			},
			{
				"filename": "app.json",
				"updater": "scripts/app-json-updater.cjs"
			}
		]
	},
	"dependencies": {
		"@expo-google-fonts/lexend": "^0.4.1",
		"@expo/vector-icons": "^15.0.3",
		"@react-native-community/datetimepicker": "8.4.4",
		"@react-navigation/bottom-tabs": "^7.13.0",
		"@react-navigation/elements": "^2.9.5",
		"@react-navigation/native": "^7.1.28",
		"drizzle-orm": "^0.45.1",
		"expo": "~54.0.33",
		"expo-application": "~7.0.8",
		"expo-constants": "~18.0.13",
		"expo-dev-client": "~6.0.20",
		"expo-document-picker": "~14.0.8",
		"expo-file-system": "^19.0.21",
		"expo-font": "~14.0.11",
		"expo-haptics": "~15.0.8",
		"expo-linking": "~8.0.11",
		"expo-router": "~6.0.23",
		"expo-sharing": "^14.0.8",
		"expo-splash-screen": "~31.0.13",
		"expo-sqlite": "^16.0.10",
		"expo-status-bar": "~3.0.9",
		"expo-symbols": "~1.0.8",
		"expo-system-ui": "~6.0.9",
		"lucide-react-native": "^0.562.0",
		"nativewind": "^4.2.1",
		"react": "19.1.0",
		"react-dom": "19.1.0",
		"react-native": "0.81.5",
		"react-native-gesture-handler": "~2.28.0",
		"react-native-reanimated": "~4.1.6",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.16.0",
		"react-native-sortables": "^1.9.4",
		"react-native-svg": "15.12.1",
		"react-native-web": "~0.21.2",
		"react-native-worklets": "0.5.1",
		"tailwindcss": "^3.4.19",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@jest/globals": "^30.2.0",
		"@resvg/resvg-js": "^2.6.2",
		"@swc/core": "^1.15.11",
		"@swc/jest": "^0.2.39",
		"@testing-library/react-native": "^13.3.3",
		"@types/better-sqlite3": "^7.6.13",
		"@types/bun": "^1.3.9",
		"@types/jest": "29.5.14",
		"@types/react": "~19.1.17",
		"babel-plugin-inline-import": "^3.0.0",
		"babel-preset-expo": "^54.0.10",
		"better-sqlite3": "^12.6.2",
		"commit-and-tag-version": "^12.6.1",
		"drizzle-kit": "^0.31.9",
		"eslint": "^9.39.2",
		"eslint-config-expo": "~10.0.0",
		"eslint-config-prettier": "^10.1.8",
		"expo-drizzle-studio-plugin": "^0.2.1",
		"jest": "~29.7.0",
		"jest-expo": "^54.0.17",
		"oxlint": "^1.47.0",
		"prettier-plugin-tailwindcss": "^0.5.14",
		"ts-jest": "^29.4.6",
		"typescript": "~5.9.3"
	},
	"private": true,
	"trustedDependencies": [
		"@swc/core",
		"unrs-resolver"
	]
}
