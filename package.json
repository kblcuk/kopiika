{
	"name": "kopiika",
	"main": "expo-router/entry",
	"version": "0.3.4",
	"scripts": {
		"start": "expo start",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"web": "expo start --web",
		"test": "bun run test:unit && bun run test:component",
		"test:unit": "bun test src/db src/store src/utils",
		"test:component": "jest",
		"test:watch": "jest --watch",
		"test:coverage": "bun test --coverage && jest --coverage",
		"lint": "oxlint",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"generate:splash": "bun run scripts/generate-splash.ts",
		"types": "tsc --noEmit",
		"release:check": "bun scripts/check-version-sync.mjs",
		"release": "bunx commit-and-tag-version",
		"release:minor": "bunx commit-and-tag-version --release-as minor",
		"release:major": "bunx commit-and-tag-version --release-as major"
	},
	"commit-and-tag-version": {
		"scripts": {
			"postbump": "mise run release:sync-build-numbers && bun run release:check"
		},
		"bumpFiles": [
			{
				"filename": "package.json",
				"type": "json"
			},
			{
				"filename": "app.json",
				"updater": "scripts/app-json-updater.mjs"
			}
		]
	},
	"dependencies": {
		"@expo-google-fonts/lexend": "^0.4.1",
		"@expo/vector-icons": "^15.1.1",
		"@react-native-community/datetimepicker": "8.6.0",
		"drizzle-orm": "^0.45.2",
		"expo": "^55.0.15",
		"expo-application": "~55.0.14",
		"expo-constants": "~55.0.14",
		"expo-dev-client": "~55.0.27",
		"expo-document-picker": "~55.0.13",
		"expo-file-system": "~55.0.16",
		"expo-font": "~55.0.6",
		"expo-haptics": "~55.0.14",
		"expo-linking": "~55.0.13",
		"expo-router": "~55.0.12",
		"expo-sharing": "~55.0.18",
		"expo-splash-screen": "~55.0.18",
		"expo-sqlite": "~55.0.15",
		"expo-status-bar": "~55.0.5",
		"expo-symbols": "~55.0.7",
		"expo-system-ui": "~55.0.15",
		"lucide-react-native": "^0.562.0",
		"nativewind": "^4.2.3",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"react-native": "0.83.4",
		"react-native-gesture-handler": "~2.30.1",
		"react-native-keyboard-controller": "1.20.7",
		"react-native-reanimated": "4.2.1",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0",
		"react-native-sortables": "^1.9.4",
		"react-native-svg": "15.15.3",
		"react-native-web": "~0.21.2",
		"react-native-worklets": "0.7.2",
		"tailwindcss": "^3.4.19",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@jest/globals": "^30.3.0",
		"@resvg/resvg-js": "^2.6.2",
		"@swc/core": "^1.15.30",
		"@swc/jest": "^0.2.39",
		"@testing-library/react-native": "^13.3.3",
		"@types/better-sqlite3": "^7.6.13",
		"@types/bun": "^1.3.12",
		"@types/jest": "29.5.14",
		"@types/react": "~19.2.14",
		"babel-plugin-inline-import": "^3.0.0",
		"babel-preset-expo": "~55.0.17",
		"better-sqlite3": "^12.9.0",
		"commit-and-tag-version": "^12.7.1",
		"drizzle-kit": "^0.31.10",
		"eslint-config-expo": "~55.0.0",
		"expo-drizzle-studio-plugin": "^0.2.1",
		"jest": "~29.7.0",
		"jest-expo": "~55.0.16",
		"oxfmt": "^0.34.0",
		"oxlint": "^1.60.0",
		"react-test-renderer": "19.2.0",
		"prettier-plugin-tailwindcss": "^0.5.14",
		"ts-jest": "^29.4.9",
		"typescript": "~5.9.3"
	},
	"private": true,
	"trustedDependencies": [
		"@swc/core",
		"unrs-resolver"
	]
}
