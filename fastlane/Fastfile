default_platform(:ios)
require 'shellwords'
require 'base64'
require 'tempfile'
require 'json'
require 'net/http'
require 'uri'
require 'fileutils'

def repo_root
  File.expand_path('..', __dir__)
end

def app_json_path
  File.join(repo_root, 'app.json')
end

def expo_config
  JSON.parse(File.read(app_json_path)).fetch('expo')
end

def app_version
  expo_config.fetch('version')
end

def ios_build_number
  expo_config.fetch('ios').fetch('buildNumber').to_s
end

def ios_info_plist_path
  File.join(repo_root, 'ios', 'kopiika', 'Info.plist')
end

def ios_project_file_path
  File.join(repo_root, 'ios', 'kopiika.xcodeproj', 'project.pbxproj')
end

def sync_ios_native_versions!
  info_plist = ios_info_plist_path
  project_file = ios_project_file_path

  set_info_plist_value(
    path: info_plist,
    key: 'CFBundleShortVersionString',
    value: app_version
  )
  set_info_plist_value(
    path: info_plist,
    key: 'CFBundleVersion',
    value: ios_build_number
  )

  project = File.read(project_file)
  project = project.gsub(
    /CURRENT_PROJECT_VERSION = [^;]+;/,
    "CURRENT_PROJECT_VERSION = #{ios_build_number};"
  )
  project = project.gsub(
    /MARKETING_VERSION = [^;]+;/,
    "MARKETING_VERSION = #{app_version};"
  )
  File.write(project_file, project)

  UI.message("Synced iOS native version to #{app_version} (#{ios_build_number})")
end

def expo_prebuild(platform)
  sh("cd #{repo_root.shellescape} && bun run expo prebuild --platform #{platform} --non-interactive --no-install")
end

def required_value!(value, message)
  return value unless value.nil? || value.to_s.strip.empty?

  UI.user_error!(message)
end

def required_env!(key, message = nil)
  required_value!(ENV[key], message || "Set #{key} in fnox or your environment.")
end

def temp_file_from_env(path_env:, data_env:, prefix:, ext:, binary: false)
  path = ENV[path_env]
  return path unless path.nil? || path.strip.empty?

  encoded_data = ENV[data_env]
  return nil if encoded_data.nil? || encoded_data.strip.empty?

  file = Tempfile.new([prefix, ext])
  file.binmode if binary
  file.write(Base64.decode64(encoded_data))
  file.flush
  file.close
  at_exit { File.delete(file.path) if File.exist?(file.path) }
  file.path
end

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV['ASC_KEY_ID'],
    issuer_id: ENV['ASC_ISSUER_ID'],
    key_content: ENV['ASC_KEY_CONTENT'],
    is_key_content_base64: true,
    in_house: false
  )
end

def ensure_asc_api_key!
  required_env!('ASC_KEY_ID')
  required_env!('ASC_ISSUER_ID')
  required_env!(
    'ASC_KEY_CONTENT',
    'Set ASC_KEY_CONTENT in fnox or your environment (base64-encoded App Store Connect key content).'
  )

  asc_api_key
end

def ios_app_identifier
  CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier)
end

def external_testflight_groups(options = {})
  groups = options[:groups] || ENV['TESTFLIGHT_EXTERNAL_GROUPS']
  return nil if groups.nil? || groups.strip.empty?

  groups
    .split(',')
    .map(&:strip)
    .reject(&:empty?)
end

def external_testflight_build(api_key, options = {})
  version =
    options[:app_version] ||
    ENV['TESTFLIGHT_APP_VERSION'] ||
    app_version

  build_number =
    options[:build_number] ||
    ENV['TESTFLIGHT_BUILD_NUMBER'] ||
    latest_testflight_build_number(
      api_key: api_key,
      version: version
    )

  {
    version: version,
    build_number: build_number.to_s
  }
end

def android_package_name
  ENV['ANDROID_PACKAGE_NAME'] || CredentialsManager::AppfileConfig.try_fetch_value(:package_name)
end

def ensure_android_package_name!
  required_value!(
    android_package_name,
    'Android package name is missing. Set package_name in fastlane/Appfile or ANDROID_PACKAGE_NAME.'
  )
end

def play_store_json_key_path
  temp_file_from_env(
    path_env: 'PLAY_STORE_JSON_KEY_PATH',
    data_env: 'PLAY_STORE_JSON_KEY_DATA',
    prefix: 'play-store-key',
    ext: '.json'
  )
end

def ensure_play_store_credentials!
  key_path = play_store_json_key_path
  UI.user_error!('Provide PLAY_STORE_JSON_KEY_PATH or PLAY_STORE_JSON_KEY_DATA (base64-encoded JSON).') if key_path.nil?
  key_path
end

def play_service_account_identity(json_key_path)
  key_json = JSON.parse(File.read(json_key_path))
  {
    client_email: key_json['client_email'],
    project_id: key_json['project_id'],
    private_key_id: key_json['private_key_id']
  }
rescue JSON::ParserError => e
  UI.user_error!("PLAY service-account JSON is invalid: #{e.message}")
rescue Errno::ENOENT
  UI.user_error!("PLAY service-account key file was not found at '#{json_key_path}'.")
end

def play_permission_error?(error)
  message = error.to_s
  message.include?('The caller does not have permission') ||
    message.include?('caller does not have permission') ||
    message.include?('permissionDenied') ||
    message.include?('insufficient permissions') ||
    message.include?('does not have Android Publisher permission')
end

def play_track_not_found_error?(error)
  message = error.to_s
  message.include?('Track not found') ||
    message.include?("undefined method `flat_map' for nil") ||
    message.include?("undefined method 'flat_map' for nil")
end

def latest_android_version_code(json_key)
  package_name = ensure_android_package_name!
  tracks = ['internal', 'alpha', 'beta', 'production']
  all_codes = []

  tracks.each do |track_name|
    begin
      codes = google_play_track_version_codes(
        json_key: json_key,
        package_name: package_name,
        track: track_name
      )
      all_codes.concat(codes || [])
    rescue StandardError => e
      return 0 if e.to_s.include?('Package not found')
      next if e.to_s.include?('Track not found')
      next if e.to_s.include?("undefined method `flat_map' for nil") || e.to_s.include?("undefined method 'flat_map' for nil")

      raise e
    end
  end

  all_codes.max || 0
end

def next_ios_build_number
  latest = latest_testflight_build_number(
    api_key: ensure_asc_api_key!,
    version: app_version,
    initial_build_number: 0
  )
  (latest.to_i + 1).to_s
rescue StandardError => e
  UI.important("Could not fetch latest TestFlight build number (#{e.class}: #{e.message}). Defaulting ios.buildNumber to 1.")
  '1'
end

def write_app_json_build_numbers!(ios_build_number:, android_version_code:)
  config = JSON.parse(File.read(app_json_path))
  config['expo'] ||= {}
  config['expo']['ios'] ||= {}
  config['expo']['android'] ||= {}
  config['expo']['ios']['buildNumber'] = ios_build_number.to_s
  config['expo']['android']['versionCode'] = android_version_code.to_i

  File.write(app_json_path, "#{JSON.pretty_generate(config).gsub('  ', "\t")}\n")
end

desc 'Sync app.json build numbers from App Store Connect and Google Play'
lane :sync_build_numbers do |options|
  ios_build_number =
    options[:ios_build_number] ||
    ENV['KOPIIKA_IOS_BUILD_NUMBER'] ||
    next_ios_build_number

  android_version_code =
    options[:android_version_code]

  if android_version_code.nil? || android_version_code.to_s.strip.empty?
    json_key = ensure_play_store_credentials!
    android_version_code = latest_android_version_code(json_key) + 1
  end

  write_app_json_build_numbers!(
    ios_build_number: ios_build_number,
    android_version_code: android_version_code
  )

  UI.success("Updated app.json: ios.buildNumber=#{ios_build_number}, android.versionCode=#{android_version_code}")
end

def first_time_play_package_error!(error)
  return false unless error.to_s.include?('Package not found')
  package_name = ensure_android_package_name!

  UI.user_error!(
    "Google Play package '#{package_name}' was not found.\n" \
      "First-time setup required in Play Console:\n" \
      "1) Create the app in Play Console (All apps -> Create app) with package '#{package_name}'.\n" \
      "2) Grant your service account access to this app in Users and permissions.\n" \
      "3) Complete required app setup/declarations in Play Console.\n" \
      'Then retry this lane.'
  )
end

def android_signing_properties
  store_file = temp_file_from_env(
    path_env: 'ANDROID_UPLOAD_STORE_FILE',
    data_env: 'ANDROID_UPLOAD_STORE_DATA',
    prefix: 'android-upload-store',
    ext: '.jks',
    binary: true
  )
  store_password = ENV['ANDROID_UPLOAD_STORE_PASSWORD']
  key_alias = ENV['ANDROID_UPLOAD_KEY_ALIAS']
  key_password = ENV['ANDROID_UPLOAD_KEY_PASSWORD']

  values = [store_file, store_password, key_alias, key_password]
  return {} if values.all? { |value| value.nil? || value.strip.empty? }

  if values.any? { |value| value.nil? || value.strip.empty? }
    UI.user_error!('Release signing requires ANDROID_UPLOAD_STORE_FILE or ANDROID_UPLOAD_STORE_DATA, plus ANDROID_UPLOAD_STORE_PASSWORD, ANDROID_UPLOAD_KEY_ALIAS, and ANDROID_UPLOAD_KEY_PASSWORD.')
  end

  {
    'android.injected.signing.store.file' => store_file,
    'android.injected.signing.store.password' => store_password,
    'android.injected.signing.key.alias' => key_alias,
    'android.injected.signing.key.password' => key_password
  }
end

# Extract a version's section from CHANGELOG.md, stripping markdown cruft.
# Returns array of {type:, items:[]} hashes, or nil if version not found.
def parsed_changelog(version = app_version)
  path = File.join(repo_root, 'CHANGELOG.md')
  return nil unless File.exist?(path)

  content = File.read(path)
  match = content.match(/^## \[#{Regexp.escape(version)}\].*?\n(.*?)(?=^## \[|\z)/m)
  return nil unless match

  sections = []
  current = nil

  match[1].strip.lines.each do |line|
    line = line.strip
    next if line.empty?

    if line.start_with?('### ')
      current = { type: line.sub('### ', ''), items: [] }
      sections << current
    elsif line =~ /^[*-]\s/ && current
      item = line
        .sub(/^[*-]\s+/, '')
        .gsub(/\*\*([\w-]+):\*\*\s*/, '')
        .gsub(/\s*\(\[[a-f0-9]+\]\([^)]+\)\)$/i, '')
        .gsub(/\s*\([a-f0-9]+\)$/i, '')
        .gsub(/,\s*closes\s.+$/i, '')
        .strip
      current[:items] << item unless item.empty?
    end
  end

  sections.reject { |s| s[:items].empty? }
end

# Plain text changelog for TestFlight "What to Test" / Play Store release notes
def changelog_for_store(version = app_version)
  sections = parsed_changelog(version)
  return nil if sections.nil? || sections.empty?

  sections.map do |s|
    "#{s[:type]}:\n" + s[:items].map { |i| "\u2022 #{i}" }.join("\n")
  end.join("\n\n")
end

# Escape Telegram Markdown v1 special characters in plain text
def escape_telegram_md(text)
  text.gsub(/([_*`\[])/, '\\\\\1')
end

# Telegram Markdown-formatted changelog
def changelog_for_telegram(version = app_version)
  sections = parsed_changelog(version)
  return nil if sections.nil? || sections.empty?

  sections.map do |s|
    "*#{s[:type]}*\n" + s[:items].map { |i| "\u2022 #{escape_telegram_md(i)}" }.join("\n")
  end.join("\n\n")
end

# Write Play Store changelog to temp metadata dir, yield path, then clean up
def with_play_changelog(text)
  Dir.mktmpdir('play-metadata') do |tmpdir|
    dir = File.join(tmpdir, 'en-US', 'changelogs')
    FileUtils.mkdir_p(dir)
    File.write(File.join(dir, 'default.txt'), text)
    yield tmpdir
  end
end

desc 'Send release notification to Telegram group'
lane :notify_telegram do |options|
  token = options[:bot_token] || ENV['TELEGRAM_BOT_TOKEN']
  chat_id = options[:chat_id] || ENV['TELEGRAM_CHAT_ID']

  unless token && chat_id
    UI.important('Skipping Telegram: TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID not set')
    next
  end

  version = options[:version] || app_version
  platform_label = options[:platform] || 'release'
  notes = changelog_for_telegram(version)

  text = "\u{1F680} *Kopiika v#{version}* \u2014 #{platform_label}"
  text += "\n\n#{notes}" if notes

  uri = URI("https://api.telegram.org/bot#{token}/sendMessage")
  response = Net::HTTP.post_form(uri, {
    'chat_id' => chat_id,
    'text' => text,
    'parse_mode' => 'Markdown'
  })

  if response.code.to_i == 200
    UI.success('Telegram notification sent')
  else
    UI.error("Telegram failed (#{response.code}): #{response.body}")
  end
end

platform :ios do
  desc 'Validate App Store Connect credentials for the current iOS version'
  lane :doctor do
    api_key = ensure_asc_api_key!
    latest_build = latest_testflight_build_number(
      api_key: api_key,
      version: app_version,
      initial_build_number: 0
    )

    UI.message("App identifier: #{ios_app_identifier || '(missing in Appfile)'}")
    UI.message("Current version: #{app_version}")
    UI.success("App Store Connect access OK. Latest TestFlight build for #{app_version}: #{latest_build}")
  rescue StandardError => e
    UI.user_error!("iOS release preflight failed: #{e.message}")
  end

  desc 'Sync code signing via match'
  lane :setup_signing do
    match(type: 'appstore', api_key: ensure_asc_api_key!)
  end

  desc 'Build the app'
  lane :build do |options|
    expo_prebuild('ios')
    sync_ios_native_versions!

    export = options[:export_method] || 'development'
    match_type = export == 'app-store' ? 'appstore' : 'development'

    match(type: match_type, api_key: ensure_asc_api_key!)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: 'ios/kopiika.xcodeproj',
      team_id: 'N84BXWAR5B',
      profile_name: ENV["sigh_com.kblcuk.kopiika_#{match_type}_profile-name"],
      code_sign_identity: match_type == 'appstore' ? 'iPhone Distribution' : 'iPhone Developer'
    )

    gym(
      workspace: 'ios/kopiika.xcworkspace',
      scheme: 'kopiika',
      export_method: export,
      export_team_id: 'N84BXWAR5B',
      xcargs: 'DEVELOPMENT_TEAM=N84BXWAR5B',
      clean: options[:clean] || false
    )
  end

  desc 'Upload latest build to TestFlight (without rebuilding)'
  lane :upload do |options|
    upload_to_testflight(
      api_key: ensure_asc_api_key!,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      changelog: options[:changelog]
    )
  end

  desc 'Promote an uploaded TestFlight build to external tester groups'
  lane :promote_external do |options|
    api_key = ensure_asc_api_key!
    groups = external_testflight_groups(options)
    build = external_testflight_build(api_key, options)

    if groups.nil? || groups.empty?
      UI.user_error!('Provide external TestFlight groups via groups: or TESTFLIGHT_EXTERNAL_GROUPS')
    end

    upload_to_testflight(
      api_key: api_key,
      distribute_only: true,
      skip_waiting_for_build_processing: false,
      skip_submission: false,
      distribute_external: true,
      groups: groups,
      app_version: build[:version],
      build_number: build[:build_number],
      changelog: options[:changelog] || changelog_for_store
    )
  end

  desc 'Push a new beta build to TestFlight'
  lane :beta do
    build(clean: true, export_method: 'app-store')
    upload(changelog: changelog_for_store)
  end
end

platform :android do
  desc 'Validate Google Play API credentials and app access before upload'
  lane :doctor do |options|
    json_key = ensure_play_store_credentials!
    package_name = options[:package_name] || ensure_android_package_name!

    identity = play_service_account_identity(json_key)
    if identity[:client_email].to_s.strip.empty?
      UI.user_error!("PLAY service-account JSON is missing 'client_email'.")
    end

    UI.message("Play service account: #{identity[:client_email]}")
    UI.message("Google Cloud project: #{identity[:project_id] || '(unknown)'}")
    UI.message("Target package: #{package_name}")

    probe_tracks = [
      options[:track],
      ENV['PLAY_TRACK'],
      'internal',
      'beta',
      'production',
      'alpha'
    ]
      .compact
      .map(&:to_s)
      .map(&:strip)
      .reject(&:empty?)
      .uniq

    UI.message("Probing Play tracks: #{probe_tracks.join(', ')}")

    readable_track_found = false

    probe_tracks.each do |track|
      begin
        version_codes = google_play_track_version_codes(
          json_key: json_key,
          package_name: package_name,
          track: track
        )

        readable_track_found = true
        codes = (version_codes || []).map(&:to_s)
        if codes.empty?
          UI.success("Play API access OK on '#{track}' track (no active releases).")
        else
          UI.success("Play API access OK on '#{track}' track (versionCodes: #{codes.join(', ')}).")
        end
        break
      rescue StandardError => e
        if e.to_s.include?('Package not found')
          first_time_play_package_error!(e)
          next
        end

        if play_permission_error?(e)
          UI.user_error!(
            "Play API permission denied for '#{identity[:client_email]}' on package '#{package_name}'.\n" \
              "Check Play Console:\n" \
              "1) Setup -> API access: linked Google Cloud project is correct and active.\n" \
              "2) Users and permissions: this service account is invited to '#{package_name}'.\n" \
              "3) App permissions include release access for the track you target.\n" \
              "4) If keys were rotated, verify PLAY_STORE_JSON_KEY_PATH / PLAY_STORE_JSON_KEY_DATA uses the latest key."
          )
        end

        if play_track_not_found_error?(e)
          UI.important("Track '#{track}' not found yet; trying next track.")
          next
        end

        raise e
      end
    end

    unless readable_track_found
      UI.important('No readable tracks found. Credentials loaded, but there may be no active releases on the probed tracks yet.')
    end

    UI.success("Android Play preflight finished for '#{package_name}'.")
  end

  desc 'Build Android release bundle (.aab)'
  lane :build do |options|
    expo_prebuild('android')

    gradle_options = {}
    gradle_options.merge!(android_signing_properties)

    if options[:clean]
      gradle(
        task: 'clean',
        project_dir: 'android',
        print_command: false
      )
    end

    gradle(
      task: 'bundle',
      build_type: 'Release',
      project_dir: 'android',
      properties: gradle_options,
      print_command: false
    )
  end

  desc 'Upload an Android bundle to Google Play'
  lane :upload do |options|
    json_key = ensure_play_store_credentials!
    package_name = ensure_android_package_name!
    track = options[:track] || ENV['PLAY_TRACK'] || 'internal'
    release_status = options[:release_status] || ENV['PLAY_RELEASE_STATUS'] || 'completed'
    aab_path = options[:aab] || ENV['PLAY_AAB_PATH'] || lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH]

    build(clean: options[:clean]) if aab_path.nil?

    changelog = changelog_for_store
    effective_aab = aab_path || lane_context[SharedValues::GRADLE_AAB_OUTPUT_PATH]

    upload_opts = {
      json_key: json_key,
      package_name: package_name,
      track: track,
      release_status: release_status,
      aab: effective_aab,
      skip_upload_apk: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    }

    begin
      if changelog
        with_play_changelog(changelog) do |metadata_path|
          upload_to_play_store(upload_opts.merge(metadata_path: metadata_path))
        end
      else
        upload_to_play_store(upload_opts)
      end
    rescue StandardError => e
      first_time_play_package_error!(e) || raise(e)
    end
  end

  desc 'Build and upload a beta build to the internal testing track'
  lane :beta do |options|
    upload(
      clean: options[:clean] || false,
      track: 'internal',
      release_status: options[:release_status] || 'completed',
      aab: options[:aab]
    )
  end

  desc 'Build and upload a production release (defaults to draft for safety)'
  lane :production do |options|
    upload(
      clean: options[:clean] || false,
      track: 'production',
      release_status: options[:release_status] || ENV['PLAY_RELEASE_STATUS'] || 'draft',
      aab: options[:aab]
    )
  end

  desc 'Promote a release from one track to another'
  lane :promote do |options|
    json_key = ensure_play_store_credentials!
    package_name = ensure_android_package_name!
    from_track = options[:from_track] || ENV['PLAY_FROM_TRACK'] || 'internal'
    to_track = options[:to_track] || ENV['PLAY_TO_TRACK'] || 'production'
    release_status = options[:release_status] || ENV['PLAY_RELEASE_STATUS'] || 'completed'

    begin
      upload_to_play_store(
        json_key: json_key,
        package_name: package_name,
        track: from_track,
        track_promote_to: to_track,
        release_status: release_status,
        skip_upload_aab: true,
        skip_upload_metadata: true,
        skip_upload_images: true,
        skip_upload_screenshots: true
      )
    rescue StandardError => e
      first_time_play_package_error!(e) || raise(e)
    end
  end
end
