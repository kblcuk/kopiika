# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

default_platform(:ios)

platform :ios do
  desc "Sync code signing via match"
  lane :setup_signing do
    match(type: "appstore")
  end

  desc "Build the app"
  lane :build do |options|
    export = options[:export_method] || "development"
    match_type = export == "app-store" ? "appstore" : "development"

    match(type: match_type)

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "ios/kopiika.xcodeproj",
      team_id: "N84BXWAR5B",
      profile_name: ENV["sigh_com.kblcuk.kopiika_#{match_type}_profile-name"],
      code_sign_identity: match_type == "appstore" ? "iPhone Distribution" : "iPhone Developer",
    )

    gym(
      workspace: "ios/kopiika.xcworkspace",
      scheme: "kopiika",
      export_method: export,
      export_team_id: "N84BXWAR5B",
      xcargs: "DEVELOPMENT_TEAM=N84BXWAR5B",
      clean: options[:clean] || false,
    )
  end

  desc "Upload latest build to TestFlight (without rebuilding)"
  lane :upload do
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      skip_submission: true
      # distribute_external: false,
      # notify_external_testers: false
    )
  end

  desc "Push a new beta build to TestFlight"
  lane :beta do
    # Increment build number before building
    increment_build_number({
      xcodeproj: "ios/kopiika.xcodeproj",
      build_number: latest_testflight_build_number + 1
    })
    build(clean: true, export_method: "app-store")
    upload(
      changelog: changelog_from_git_commits(
        pretty: "- %s",# Optional, lets you provide a custom format to apply to each commit when generating the changelog text
      )
    )
  end
end
