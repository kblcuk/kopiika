{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"experimentalTailwindcss": {},
	"semi": true,
	"singleQuote": true,
	"trailingComma": "es5",
	"printWidth": 100,
	"tabWidth": 4,
	"useTabs": true,
	"experimentalSortPackageJson": false,
	"ignorePatterns": [
		"package-lock.json",
		"pnpm-lock.yaml",
		"yarn.lock",
		"bun.lock",
		"bun.lockb",
		"fnox.toml", // managed by fnox
		"CHANGELOG.md", // managed by release file
		"fastlane/README.md", // managed by Fastlane
		"coverage/**",
		"node_modules/**",
		"dist/**",
		".expo/**",
		"ios/**",
		"android/**",
		"!/static",
		"/static/*",
		"!/static/fonts",
		"!/static/fonts/fonts.css",
		".coverage"
	]
}
