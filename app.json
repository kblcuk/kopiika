{
	"expo": {
		"name": "kopiika",
		"slug": "kopiika",
		"version": "0.2.18",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "kopiika",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.kblcuk.kopiika",
			"appleTeamId": "N84BXWAR5B",
			"config": {
				"usesNonExemptEncryption": false
			},
			"buildNumber": "1"
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#E6F4FE",
				"foregroundImage": "./assets/images/android-icon-foreground.png",
				"backgroundImage": "./assets/images/android-icon-background.png",
				"monochromeImage": "./assets/images/android-icon-monochrome.png"
			},
			"edgeToEdgeEnabled": true,
			"package": "com.kblcuk.kopiika",
			"versionCode": 25
		},
		"web": {
			"output": "static",
			"bundler": "metro",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"./plugins/with-match-signing",
				{
					"targetName": "kopiika",
					"appleTeamId": "N84BXWAR5B",
					"developmentProfileName": "match Development com.kblcuk.kopiika",
					"distributionProfileName": "match AppStore com.kblcuk.kopiika"
				}
			],
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/splash-icon.png",
					"imageWidth": 280,
					"resizeMode": "contain",
					"backgroundColor": "#F8F4ED",
					"dark": {
						"image": "./assets/images/splash-icon-dark.png",
						"backgroundColor": "#1A1410"
					}
				}
			]
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true
		}
	}
}
